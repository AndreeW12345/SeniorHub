{
  "expo": {
    "name": "SeniorHub",
    "slug": "SeniorHub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "seniorhub",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.andreew12345.seniorhub",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#004E87",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SeniorHub behöver tillgång till dina bilder så att administratörer kan välja en aktivitetsbild.",
          "cameraPermission": "SeniorHub behöver tillgång till kameran så att administratörer kan ta en aktivitetsbild.",
          "microphonePermission": false
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "SeniorHub behöver tillgång till din kalender för att lägga till aktiviteter.",
          "writeOnlyAccess": true,
          "writeOnlyCalendarPermission": "SeniorHub behöver tillgång för att lägga till aktiviteter i din kalender."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "92ad3b95-c275-4c2b-8306-90cbf0533360"
      }
    }
  }
}
