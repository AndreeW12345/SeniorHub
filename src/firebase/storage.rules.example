rules_version = '2';

// Example Firebase Storage rules for SeniorHub activity images.
// Deploy in Firebase Console → Storage → Rules.
service firebase.storage {
  match /b/{bucket}/o {
    match /activities/{allPaths=**} {
      // Anyone can view activity images in the app.
      allow read: if true;

      // Only signed-in admins can upload or replace images.
      allow write: if request.auth != null;
    }
  }
}
